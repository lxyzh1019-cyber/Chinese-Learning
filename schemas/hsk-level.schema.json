{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chinese-adventure.local/schemas/hsk-level.schema.json",
  "title": "HSKLevelCurriculum",
  "type": "object",
  "required": [
    "level",
    "sourceStandard",
    "totalWords",
    "totalGates",
    "gateDistribution",
    "words",
    "gates"
  ],
  "properties": {
    "level": {
      "type": "string",
      "pattern": "^HSK[1-4]$"
    },
    "sourceStandard": {
      "type": "string"
    },
    "totalWords": {
      "type": "integer",
      "const": 300
    },
    "totalGates": {
      "type": "integer",
      "const": 22
    },
    "gateDistribution": {
      "type": "array",
      "minItems": 22,
      "maxItems": 22,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "words": {
      "type": "array",
      "minItems": 300,
      "maxItems": 300,
      "items": {
        "$ref": "#/$defs/wordItem"
      }
    },
    "gates": {
      "type": "array",
      "minItems": 22,
      "maxItems": 22,
      "items": {
        "$ref": "#/$defs/gateItem"
      }
    }
  },
  "$defs": {
    "wordItem": {
      "type": "object",
      "required": [
        "zh",
        "pinyin",
        "en",
        "sourceLevel",
        "sourceTag",
        "tags",
        "difficulty"
      ],
      "properties": {
        "zh": { "type": "string", "minLength": 1 },
        "pinyin": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 },
        "sourceLevel": { "type": "string" },
        "sourceTag": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        },
        "meta": {
          "type": "object",
          "properties": {
            "frequency": {
              "type": ["integer", "null"]
            },
            "pos": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "gateItem": {
      "type": "object",
      "required": [
        "gateId",
        "theme",
        "sentenceTargets",
        "rewards",
        "newWords",
        "reviewWords"
      ],
      "properties": {
        "gateId": {
          "type": "integer",
          "minimum": 1,
          "maximum": 22
        },
        "theme": { "type": "string" },
        "sentenceTargets": {
          "type": "integer",
          "minimum": 1
        },
        "rewards": {
          "$ref": "#/$defs/rewardItem"
        },
        "newWords": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/wordItem"
          }
        },
        "reviewWords": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/wordItem"
          }
        }
      },
      "additionalProperties": true
    },
    "rewardItem": {
      "type": "object",
      "required": ["stars", "mysteryBoxChance", "familyRewardType"],
      "properties": {
        "stars": {
          "type": "integer",
          "minimum": 0
        },
        "mysteryBoxChance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "familyRewardType": {
          "type": ["string", "null"],
          "enum": [
            "ask_parents_help",
            "movie_night",
            "game_night",
            "choose_dinner",
            null
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
