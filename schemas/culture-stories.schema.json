{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/schemas/culture-stories.schema.json",
  "title": "CultureStoryTrack",
  "type": "object",
  "required": ["trackId", "version", "rewardCatalog", "tracks"],
  "properties": {
    "trackId": { "type": "string" },
    "version": { "type": "integer" },
    "description": { "type": "string" },
    "totalStories": { "type": "integer", "minimum": 0 },
    "rewardCatalog": {
      "type": "object",
      "required": ["familyRewardTypes"],
      "properties": {
        "familyRewardTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["ask_parents_help", "movie_night", "game_night", "choose_dinner"]
          }
        }
      },
      "additionalProperties": false
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "stories"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "stories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "title", "season", "hskBand", "focusTags", "targetWords", "rewards"],
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "season": { "type": "string" },
                "hskBand": {
                  "type": "string",
                  "enum": ["HSK1", "HSK2", "HSK3", "HSK4"]
                },
                "focusTags": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "targetWords": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "readerParagraphs": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "readerComprehension": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["question", "answer"],
                    "properties": {
                      "question": { "type": "string" },
                      "answer": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                },
                "rewards": {
                  "type": "object",
                  "required": ["stars", "badgeFragments", "mysteryBoxToken", "familyRewardType"],
                  "properties": {
                    "stars": { "type": "integer", "minimum": 0 },
                    "badgeFragments": { "type": "integer", "minimum": 0 },
                    "mysteryBoxToken": { "type": "integer", "minimum": 0 },
                    "familyRewardType": {
                      "type": ["string", "null"],
                      "enum": ["ask_parents_help", "movie_night", "game_night", "choose_dinner", null]
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
